{
  "name": "rumdl-plugin",
  "version": "1.0.8",
  "license": "Apache-2.0",
  "repository": "https://github.com/cjhowe-us/rumdl-plugin",
  "author": {
    "name": "Christian Howe",
    "url": "https://github.com/cjhowe-us"
  },
  "description": "Markdown linting and formatting via rumdl: LSP server for live diagnostics, PostToolUse hook that runs `rumdl fmt` after every Markdown edit, and the Markdown coding-standard skill.",
  "keywords": [
    "formatter",
    "gfm",
    "linter",
    "lsp",
    "markdown",
    "rumdl",
    "rust"
  ],
  "lspServers": {
    "rumdl": {
      "args": [
        "server",
        "--stdio"
      ],
      "command": "rumdl",
      "extensionToLanguage": {
        ".md": "markdown"
      }
    }
  }
}
